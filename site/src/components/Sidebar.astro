---
// Left-rail file-tree sidebar - walks all 3 content collections and renders a
// collapsible tree. Visible at >=1280px, hidden on narrower screens.
//
// Active-doc highlighting derived from Astro.url.pathname. Folder open/closed
// state persisted in localStorage by client-side script.

import { getCollection } from 'astro:content';
import SidebarNode from './SidebarNode.astro';

interface Node {
  type: 'folder' | 'doc';
  name: string;
  href?: string;
  children?: Node[];
}

interface CollectionTree {
  collection: 'reference' | 'research' | 'whitepaper';
  label: string;
  root: Node[];
}

function deriveTitle(slug: string, body: string | undefined): string {
  const h1 = body?.match(/^#\s+(.+)$/m)?.[1];
  if (h1) {
    // Trim long titles for the sidebar
    return h1.length > 60 ? h1.slice(0, 57) + '…' : h1;
  }
  return slug.split('/').pop()!.replace(/^\d+[a-z]?-/, '').replace(/-/g, ' ');
}

async function buildTree(collection: 'reference' | 'research' | 'whitepaper'): Promise<Node[]> {
  const docs = await getCollection(collection);
  const root: Node[] = [];
  const folderMap = new Map<string, Node>();

  // Sort docs so READMEs come first per folder, then by leading number, then alpha.
  const sorted = docs.slice().sort((a, b) => {
    const aPath = a.id;
    const bPath = b.id;
    const aReadme = aPath.toLowerCase().includes('readme') ? -2 : 0;
    const bReadme = bPath.toLowerCase().includes('readme') ? -2 : 0;
    const aIndex = aPath.toLowerCase().includes('index') ? -1 : 0;
    const bIndex = bPath.toLowerCase().includes('index') ? -1 : 0;
    const aScore = aReadme + aIndex;
    const bScore = bReadme + bIndex;
    if (aScore !== bScore) return aScore - bScore;
    const aNum = parseInt(aPath.split('/').pop()!.match(/^(\d+)/)?.[1] ?? '999', 10);
    const bNum = parseInt(bPath.split('/').pop()!.match(/^(\d+)/)?.[1] ?? '999', 10);
    if (aNum !== bNum) return aNum - bNum;
    return aPath.localeCompare(bPath);
  });

  for (const doc of sorted) {
    const slug = doc.id.replace(/\.md$/, '');
    const segments = slug.split('/');
    const fileName = segments.pop()!;
    const href = `/${collection}/${slug}`;
    const title = deriveTitle(doc.id, doc.body);

    // Walk/create the folder chain
    let parentChildren = root;
    let pathSoFar = '';
    for (const seg of segments) {
      pathSoFar = pathSoFar ? `${pathSoFar}/${seg}` : seg;
      const folderKey = `${collection}:${pathSoFar}`;
      let folder = folderMap.get(folderKey);
      if (!folder) {
        folder = { type: 'folder', name: seg, children: [] };
        folderMap.set(folderKey, folder);
        parentChildren.push(folder);
      }
      parentChildren = folder.children!;
    }
    parentChildren.push({ type: 'doc', name: title, href });
  }
  return root;
}

const trees: CollectionTree[] = [
  { collection: 'reference', label: 'Reference', root: await buildTree('reference') },
  { collection: 'research', label: 'Research', root: await buildTree('research') },
  { collection: 'whitepaper', label: 'Whitepaper', root: await buildTree('whitepaper') },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '');
---
<aside class="sidebar" aria-label="Documentation index">
  {trees.map((tree) => (
    <section class="sb-section">
      <h2 class="sb-section-label">
        <a href={`/${tree.collection}`}>{tree.label}</a>
      </h2>
      <ul class="sb-list">
        {tree.root.map((node) => <SidebarNode node={node} currentPath={currentPath} parentKey={tree.collection} />)}
      </ul>
    </section>
  ))}
</aside>

<script>
  // Persist folder open/closed state in localStorage. Keyed by folder data attribute.
  const STORE_KEY = 'zf-sidebar-folders';
  const stored: Record<string, boolean> = (() => {
    try { return JSON.parse(localStorage.getItem(STORE_KEY) || '{}'); } catch { return {}; }
  })();

  document.querySelectorAll<HTMLDetailsElement>('details[data-folder]').forEach((d) => {
    const key = d.dataset.folder!;
    if (typeof stored[key] === 'boolean') d.open = stored[key];
    d.addEventListener('toggle', () => {
      stored[key] = d.open;
      try { localStorage.setItem(STORE_KEY, JSON.stringify(stored)); } catch {}
    });
  });
</script>

<style>
  .sidebar {
    font-size: 0.85rem;
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 7rem);
    overflow-y: auto;
    padding: 0.25rem 0.5rem 1rem 0;
    color: var(--text-muted);
  }
  .sidebar::-webkit-scrollbar { width: 6px; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  .sb-section {
    margin-bottom: 1.5rem;
  }
  .sb-section-label {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.7rem !important;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--orange);
    margin: 0 0 0.5rem 0;
  }
  .sb-section-label a {
    color: inherit;
    border: none;
  }
  .sb-section-label a:hover { color: var(--gold); }
  .sb-list, .sb-children {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .sb-list a, .sb-children a {
    display: block;
    padding: 0.18rem 0.4rem;
    color: var(--text-muted);
    border: none;
    line-height: 1.4;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
    font-size: 0.83rem;
  }
  .sb-list a:hover, .sb-children a:hover { color: var(--cyan); background: var(--bg-elev); }
  .sb-list a.active, .sb-children a.active {
    color: var(--gold);
    background: var(--bg-elev);
    font-weight: 600;
  }
  details {
    margin: 0.15rem 0;
  }
  details summary {
    cursor: pointer;
    padding: 0.18rem 0.4rem;
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 0.83rem;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    border-radius: 4px;
  }
  details summary::-webkit-details-marker { display: none; }
  details summary::before {
    content: '>';
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-dim);
    transition: transform 0.15s;
    display: inline-block;
    width: 0.7rem;
  }
  details[open] summary::before {
    transform: rotate(90deg);
  }
  details summary:hover { background: var(--bg-elev); color: var(--cyan); }
  .sb-children {
    padding-left: 1rem;
    border-left: 1px dashed var(--border);
    margin-left: 0.5rem;
  }
  @media (max-width: 1279px) {
    .sidebar { display: none; }
  }
</style>

<script type="module" is:inline>
// Note: render of SidebarNode is recursive; emit inline below via Astro fragment.
</script>

<style>
  /* The SidebarNode is inlined below via a fragment. Astro recursive components
     require a tiny dedicated file; for simplicity we expand 3 levels inline. */
</style>
