---
interface NavLink {
  href: string;
  title: string;
}

interface Props {
  prev?: NavLink | null;
  next?: NavLink | null;
}

const { prev, next } = Astro.props;
---
{(prev || next) && (
  <nav class="prev-next" aria-label="Adjacent documents">
    {prev ? (
      <a href={prev.href} class="pn-link pn-prev">
        <span class="pn-dir">&larr; Prev</span>
        <span class="pn-title">{prev.title}</span>
      </a>
    ) : <span></span>}
    {next ? (
      <a href={next.href} class="pn-link pn-next">
        <span class="pn-dir">Next &rarr;</span>
        <span class="pn-title">{next.title}</span>
      </a>
    ) : <span></span>}
  </nav>
)}

<style>
  .prev-next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 3rem 0 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .pn-link {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.15rem;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s, transform 0.15s;
  }
  .pn-link:hover {
    border-color: var(--orange);
    transform: translateY(-2px);
  }
  .pn-prev { text-align: left; }
  .pn-next { text-align: right; align-items: flex-end; }
  .pn-dir {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .pn-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--cyan);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    line-height: 1.3;
  }
  @media (max-width: 600px) {
    .prev-next { grid-template-columns: 1fr; }
    .pn-next { text-align: left; align-items: flex-start; }
  }
</style>
