---
// Inline share bar - Farcaster (Warpcast composeCast), X, copy link.
// Mounted at top of each doc page after the title block.

interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

// Warpcast composeCast deep link. The embeds[]= parameter unfurls the URL as a card in the cast.
const castText = `${title} - via @bettercallzaal`;
const warpcastUrl = `https://warpcast.com/~/compose?text=${encodeURIComponent(castText)}&embeds[]=${encodeURIComponent(url)}`;
const xUrl = `https://x.com/intent/post?text=${encodeURIComponent(castText)}&url=${encodeURIComponent(url)}`;
---
<div class="sharebar" aria-label="Share this page">
  <a href={warpcastUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-fc" title="Cast on Farcaster">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 1000 1000" fill="currentColor" aria-hidden="true">
      <path d="M257.778 155.556h484.444v688.889h-71.111V528.889h-.697c-7.86-87.212-81.156-155.556-170.414-155.556s-162.554 68.344-170.414 155.556h-.697v315.555h-71.111V155.556Z"/>
      <path d="M128.889 253.333 157.778 351.111h24.444v395.556a24.444 24.444 0 0 0-24.444 24.444v26.667h-4.444A24.444 24.444 0 0 0 128.889 822.222v26.667h271.111v-26.667A24.444 24.444 0 0 0 375.556 797.778h-4.444v-26.667A24.444 24.444 0 0 0 346.667 746.667V253.333H128.889Zm539.555 493.334a24.444 24.444 0 0 0-22.221 24.444v26.667h-4.444A24.444 24.444 0 0 0 617.333 822.222v26.667h271.112v-26.667A24.444 24.444 0 0 0 864 797.778h-4.445v-26.667a24.444 24.444 0 0 0-22.222-24.444V351.111h24.445L890.667 253.333h-217.78V746.667h-4.443Z"/>
    </svg>
    <span class="share-label">Cast</span>
  </a>
  <a href={xUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-x" title="Share on X">
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
    <span class="share-label">X</span>
  </a>
  <button class="share-btn share-copy" data-share-url={url} type="button" title="Copy link">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
    </svg>
    <span class="share-label">Copy link</span>
  </button>
</div>

<script>
  document.addEventListener('click', async (e) => {
    const btn = (e.target as Element).closest('button.share-copy');
    if (!btn) return;
    const url = btn.getAttribute('data-share-url');
    if (!url) return;
    try {
      await navigator.clipboard.writeText(url);
      const label = btn.querySelector('.share-label');
      const orig = label?.textContent ?? 'Copy link';
      if (label) label.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        if (label) label.textContent = orig;
        btn.classList.remove('copied');
      }, 1500);
    } catch {}
  });
</script>

<style>
  .sharebar {
    display: flex;
    gap: 0.5rem;
    margin: 0.5rem 0 1.5rem;
    flex-wrap: wrap;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.7rem;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.8rem;
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .share-btn:hover { border-color: var(--orange); color: var(--text); }
  .share-fc:hover { border-color: #8a5cf6; }
  .share-x:hover { border-color: var(--text); }
  .share-copy.copied { border-color: var(--cyan); color: var(--cyan); }
  .share-btn svg { flex-shrink: 0; }
  @media (max-width: 600px) {
    .share-label { display: none; }
    .share-btn { padding: 0.35rem 0.6rem; }
  }
</style>
