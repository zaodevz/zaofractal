---
// Pagefind search UI: cmd+K modal + always-visible search input on /search page if needed.
// Mount this in BaseLayout. The astro-pagefind integration runs Pagefind after build
// and serves /pagefind/pagefind-ui.js automatically.
---
<div id="search-trigger" class="search-trigger" role="button" tabindex="0" aria-label="Open search (cmd+K)">
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="7"/>
    <path d="m21 21-4.3-4.3"/>
  </svg>
  <span class="trigger-label">Search</span>
  <kbd class="kbd">cmd K</kbd>
</div>

<div id="search-modal" class="search-modal" aria-hidden="true" role="dialog" aria-label="Search">
  <div class="search-backdrop" data-close></div>
  <div class="search-panel">
    <div id="search-mount"></div>
    <div class="search-hint">
      <span class="dim">Press <kbd class="kbd">esc</kbd> to close</span>
    </div>
  </div>
</div>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css">

<script>
  // Lazy-init Pagefind UI on first open. Bind cmd+K + button click + esc to close.
  let pagefindInited = false;
  const trigger = document.getElementById('search-trigger');
  const modal = document.getElementById('search-modal');
  const mount = document.getElementById('search-mount');

  async function initPagefind() {
    if (pagefindInited || !mount) return;
    try {
      // Pagefind UI is generated by astro-pagefind AFTER the Vite build, so Vite
      // can't resolve this import statically. Use string-templated path + @vite-ignore.
      const url = '/pagefind/pagefind-ui.js';
      // @ts-ignore - external module loaded post-build
      const mod = await import(/* @vite-ignore */ url);
      const PagefindUI = mod.PagefindUI;
      new PagefindUI({
        element: '#search-mount',
        showSubResults: true,
        showImages: false,
        resetStyles: false,
        autofocus: true,
        translations: {
          placeholder: 'Search ZAOfractal',
          clear_search: 'Clear',
          load_more: 'Load more',
          search_label: 'Search',
          filters_label: 'Filters',
          zero_results: 'No results for [SEARCH_TERM]',
          many_results: '[COUNT] results for [SEARCH_TERM]',
          one_result: '[COUNT] result for [SEARCH_TERM]',
          searching: 'Searching for [SEARCH_TERM]...',
        },
      });
      pagefindInited = true;
    } catch (err) {
      mount.innerHTML = '<p class="muted">Search index not built yet. Run <code>npm run build</code> locally.</p>';
    }
  }

  function openSearch() {
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'false');
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
    initPagefind();
    setTimeout(() => {
      const input = modal.querySelector('input');
      if (input instanceof HTMLInputElement) input.focus();
    }, 50);
  }
  function closeSearch() {
    if (!modal) return;
    modal.setAttribute('aria-hidden', 'true');
    modal.classList.remove('open');
    document.body.style.overflow = '';
  }

  trigger?.addEventListener('click', openSearch);
  trigger?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      openSearch();
    }
  });
  modal?.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', closeSearch));
  document.addEventListener('keydown', (e) => {
    const isCmdK = (e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k';
    if (isCmdK) {
      e.preventDefault();
      if (modal?.classList.contains('open')) closeSearch();
      else openSearch();
    } else if (e.key === 'Escape') {
      if (modal?.classList.contains('open')) closeSearch();
    }
  });
</script>

<style>
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.85rem;
    transition: border-color 0.15s, color 0.15s;
  }
  .search-trigger:hover {
    border-color: var(--orange);
    color: var(--text);
  }
  .search-trigger svg { color: var(--text-dim); }
  .trigger-label { font-weight: 500; }
  .kbd {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.05rem 0.4rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.7rem;
    color: var(--text-dim);
  }
  .search-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    align-items: flex-start;
    justify-content: center;
    padding: 12vh 1rem 4rem;
  }
  .search-modal.open { display: flex; }
  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(5, 5, 15, 0.85);
    backdrop-filter: blur(8px);
  }
  .search-panel {
    position: relative;
    width: 100%;
    max-width: 640px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    padding: 1.25rem;
    z-index: 1;
  }
  .search-hint {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    text-align: right;
  }
  /* Pagefind UI overrides for our dark theme */
  :global(.pagefind-ui) {
    --pagefind-ui-primary: var(--orange);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--bg-card);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--bg-elev);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: 'Outfit', system-ui, sans-serif;
  }
  :global(.pagefind-ui .pagefind-ui__search-input) {
    background: var(--bg-card) !important;
    color: var(--text) !important;
    border-color: var(--border) !important;
    font-family: 'Outfit', system-ui, sans-serif !important;
  }
  :global(.pagefind-ui .pagefind-ui__result-link) {
    color: var(--cyan) !important;
    font-family: 'Syne', sans-serif !important;
    font-weight: 700 !important;
  }
  :global(.pagefind-ui .pagefind-ui__result-excerpt mark) {
    background: rgba(255, 201, 60, 0.25);
    color: var(--gold);
    padding: 0 0.2em;
  }
  :global(.pagefind-ui .pagefind-ui__message) {
    color: var(--text-muted) !important;
  }
  @media (max-width: 600px) {
    .trigger-label { display: none; }
    .search-modal { padding-top: 6vh; }
  }
</style>
