---
import Search from './Search.astro';
import MobileNav from './MobileNav.astro';
const { pathname } = Astro.url;
const isActive = (p: string) => pathname === p || pathname.startsWith(p + '/');
const links = [
  { href: '/reference', label: 'Reference' },
  { href: '/research', label: 'Research' },
  { href: '/whitepaper', label: 'Whitepaper' },
  { href: '/resources', label: 'Resources' },
];
---
<header class="site-nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <span class="brand-z">ZAO</span><span class="brand-rest">fractal</span>
    </a>
    <nav class="desktop-nav">
      {links.map(l => (
        <a href={l.href} class={isActive(l.href) ? 'active' : ''}>{l.label}</a>
      ))}
    </nav>
    <div class="nav-right">
      <Search />
      <MobileNav />
    </div>
  </div>
</header>

<style>
  .site-nav {
    border-bottom: 1px solid var(--border);
    background: rgba(10, 10, 26, 0.85);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .nav-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0.85rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .brand {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    border: none;
    color: var(--text);
  }
  .brand-z { color: var(--orange); }
  .brand-rest { color: var(--cyan); }
  .desktop-nav {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    flex: 1;
    justify-content: center;
  }
  .desktop-nav a {
    color: var(--text-muted);
    border: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.15s;
  }
  .desktop-nav a:hover { color: var(--orange); }
  .desktop-nav a.active { color: var(--gold); }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  @media (max-width: 720px) {
    .nav-inner { padding: 0.7rem 0.85rem; gap: 0.6rem; }
    .desktop-nav { display: none; }
    .nav-right { gap: 0.4rem; }
  }
</style>
