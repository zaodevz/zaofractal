---
const { pathname } = Astro.url;
const isActive = (p: string) => pathname === p || pathname.startsWith(p + '/');
const links = [
  { href: '/', label: 'Home' },
  { href: '/reference', label: 'Reference' },
  { href: '/research', label: 'Research' },
  { href: '/whitepaper', label: 'Whitepaper' },
  { href: '/resources', label: 'Resources' },
];
---
<header class="site-nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <span class="brand-z">ZAO</span><span class="brand-rest">fractal</span>
    </a>
    <nav>
      {links.slice(1).map(l => (
        <a href={l.href} class={isActive(l.href) ? 'active' : ''}>{l.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-nav {
    border-bottom: 1px solid var(--border);
    background: rgba(10, 10, 26, 0.85);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.9rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .brand {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    border: none;
    color: var(--text);
  }
  .brand-z { color: var(--orange); }
  .brand-rest { color: var(--cyan); }
  nav {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  nav a {
    color: var(--text-muted);
    border: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.15s;
  }
  nav a:hover { color: var(--orange); }
  nav a.active {
    color: var(--gold);
  }
  @media (max-width: 600px) {
    .nav-inner { padding: 0.7rem 0.85rem; flex-direction: column; align-items: flex-start; }
    nav { gap: 0.85rem; }
    nav a { font-size: 0.9rem; }
  }
</style>
