---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ZAO Fractal - the weekly Respect Game, ORDAO governance, and the lineage of fractal democracy.' } = Astro.props;
const fullTitle = title === 'ZAOfractal' ? title : `${title} - ZAOfractal`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary" />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{fullTitle}</title>
</head>
<body>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
  <script>
    // Copy-button handler for code blocks. Listens once, delegates to any .copy click.
    document.addEventListener('click', async (e) => {
      const btn = (e.target as Element).closest('button.copy');
      if (!btn) return;
      const pre = btn.parentElement;
      if (!pre) return;
      const code = pre.querySelector('code')?.innerText ?? pre.innerText;
      try {
        await navigator.clipboard.writeText(code.replace(/\n$/, ''));
        btn.classList.add('copied');
        btn.setAttribute('title', 'Copied!');
        setTimeout(() => {
          btn.classList.remove('copied');
          btn.setAttribute('title', 'Copy');
        }, 1500);
      } catch (err) {
        btn.setAttribute('title', 'Copy failed');
      }
    });

    // Contract-address pills: also copy on click (in addition to opening Etherscan in new tab)
    document.addEventListener('click', async (e) => {
      const link = (e.target as Element).closest('a.contract-address');
      if (!link) return;
      if ((e as MouseEvent).altKey) {
        // alt+click copies without navigating
        e.preventDefault();
        const addr = link.getAttribute('data-address');
        if (addr) {
          try {
            await navigator.clipboard.writeText(addr);
            const orig = link.getAttribute('title');
            link.setAttribute('title', 'Copied!');
            setTimeout(() => { if (orig) link.setAttribute('title', orig); }, 1500);
          } catch (err) {}
        }
      }
    });
  </script>
</body>
</html>
