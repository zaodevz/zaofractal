---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { getCollection } from 'astro:content';
import { currentFractalWeek } from '../lib/week';

const reference = await getCollection('reference');
const research = await getCollection('research');
const whitepaper = await getCollection('whitepaper');

const refCount = reference.length;
const resCount = research.length;
const wpCount = whitepaper.length;
const weekNumber = currentFractalWeek();
---
<BaseLayout title="ZAOfractal">
  <Hero weekNumber={weekNumber} />

  <h2>Browse the docs</h2>
  <div class="doc-grid">
    <div class="doc-card">
      <a href="/reference">
        <div class="title tag-orange">Reference</div>
        <div class="meta">{refCount} files - shallow lineage survey</div>
        <p class="muted" style="margin-top: 0.5rem; font-size: 0.9rem;">
          Every fractal that ever existed (Larimer, Fractally, Eden, Optimism, Roy, Aquadac).
          Start here.
        </p>
      </a>
    </div>
    <div class="doc-card">
      <a href="/research">
        <div class="title tag-cyan">Research</div>
        <div class="meta">{resCount} files - DEEP-tier, 500+ sources</div>
        <p class="muted" style="margin-top: 0.5rem; font-size: 0.9rem;">
          Theory, mechanism, ORDAO contracts, communities, music, async, identity,
          tooling, the full Optimystics catalog, and history of every fractal end to end.
        </p>
      </a>
    </div>
    <div class="doc-card">
      <a href="/whitepaper">
        <div class="title tag-gold">Whitepaper</div>
        <div class="meta">{wpCount} files - magnum opus drafts</div>
        <p class="muted" style="margin-top: 0.5rem; font-size: 0.9rem;">
          The ZAO Fractal Whitepaper. Chapters 1-3 in v0.1 draft. Chapters 4-11
          still to come.
        </p>
      </a>
    </div>
    <div class="doc-card">
      <a href="/resources">
        <div class="title tag-orange">Resources</div>
        <div class="meta">Master index</div>
        <p class="muted" style="margin-top: 0.5rem; font-size: 0.9rem;">
          Every person, organization, community, contract, tool, paper, and URL
          cited across the repo. One place to find any reference.
        </p>
      </a>
    </div>
  </div>

  <h2>Visual explorations</h2>
  <p class="muted">
    Two pages built on top of the canonical Markdown source for non-linear browsing.
  </p>
  <div class="doc-grid">
    <div class="doc-card">
      <a href="/lineage">
        <div class="title tag-cyan">Lineage timeline</div>
        <div class="meta">2014 -> 2026 - the fractal-democracy story</div>
        <p class="muted" style="margin-top: 0.5rem; font-size: 0.9rem;">
          Larimer's BitShares through ZAO Fractal Week {weekNumber}. Every milestone color-coded by era.
        </p>
      </a>
    </div>
    <div class="doc-card">
      <a href="/people">
        <div class="title tag-gold">People</div>
        <div class="meta">Who built this lineage</div>
        <p class="muted" style="margin-top: 0.5rem; font-size: 0.9rem;">
          Larimer, SingJoy, Tadas, Zaal, Mikael, plus the founders of every active fractal community.
        </p>
      </a>
    </div>
  </div>

  <h2>Live ZAO Fractal facts</h2>
  <table>
    <tbody>
      <tr><td><strong>Cadence</strong></td><td>Mondays 6pm EST, weekly. Also runs anytime with 4+ unplayed members.</td></tr>
      <tr><td><strong>Streak</strong></td><td>Week {weekNumber}+ continuous</td></tr>
      <tr><td><strong>Surface</strong></td><td>Discord bot <code>fractalbotmarch2026</code> (52 slash commands, v2.1)</td></tr>
      <tr><td><strong>Chain</strong></td><td>Optimism (OP Mainnet)</td></tr>
      <tr><td><strong>OREC executor</strong></td><td><code>0xcB05F9254765CA521F7698e61E0A6CA6456Be532</code></td></tr>
      <tr><td><strong>OG Respect (ERC-20, fractals 1-73)</strong></td><td><code>0x34cE89baA7E4a4B00E17F7E4C0cb97105C216957</code></td></tr>
      <tr><td><strong>ZOR Respect (ERC-1155, fractals 74+)</strong></td><td><code>0x9885CCeEf7E8371Bf8d6f2413723D25917E7445c</code></td></tr>
      <tr><td><strong>Submission UI</strong></td><td><a href="https://zao.frapps.xyz/submitBreakout">zao.frapps.xyz/submitBreakout</a></td></tr>
      <tr><td><strong>OREC transactions</strong></td><td>242+ as of May 21, 2026</td></tr>
    </tbody>
  </table>

  <h2>About this site</h2>
  <p>
    Auto-generated from the Markdown source in the
    <a href="https://github.com/ZAODEVZ/ZAOfractal">ZAODEVZ/ZAOfractal</a> repo
    via Astro. Every file under <code>reference/</code>, <code>research/</code>,
    and <code>whitepaper/</code> in the repo gets a page here. Push to <code>main</code>
    and the site rebuilds.
  </p>
</BaseLayout>
