---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const docs = await getCollection('whitepaper');

function deriveTitle(slug: string, body: string | undefined) {
  const h1 = body?.match(/^#\s+(.+)$/m)?.[1];
  if (h1) return h1.trim();
  return slug.split('/').pop()!.replace(/\.md$/, '').replace(/^ch?\d+-/, '').replace(/-/g, ' ');
}

const ordered = docs.slice().sort((a, b) => {
  if (a.id.toLowerCase() === 'readme' || a.id.toLowerCase() === 'readme.md') return -1;
  if (b.id.toLowerCase() === 'readme' || b.id.toLowerCase() === 'readme.md') return 1;
  return a.id.localeCompare(b.id);
});
---
<BaseLayout title="Whitepaper">
  <h1>The ZAO Fractal Whitepaper</h1>
  <p class="muted">
    The magnum opus governance document for The ZAO. Chapters 1-3 in v0.1 first
    draft. Chapters 4-11 still to come. Awaiting Zaal review at every chapter.
  </p>

  <div class="doc-grid">
    {ordered.map((doc) => {
      const title = deriveTitle(doc.id, doc.body);
      const href = `/whitepaper/${doc.id.replace(/\.md$/, '')}`;
      return (
        <div class="doc-card">
          <a href={href}>
            <div class="title">{title}</div>
            <div class="meta">{doc.id}</div>
          </a>
        </div>
      );
    })}
  </div>
</BaseLayout>
