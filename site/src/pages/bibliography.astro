---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Build a deduplicated, alphabetized bibliography from every doc's Sources section.
// Pattern matched: `- [Title](URL)` and `[Title](URL)` lines inside Sources sections.

interface Entry {
  title: string;
  url: string;
  origin: string;
}

function extractSources(body: string, origin: string): Entry[] {
  if (!body) return [];
  const out: Entry[] = [];
  const lines = body.split('\n');
  let inSources = false;
  for (const line of lines) {
    if (/^#{2,4}\s+Sources/i.test(line)) {
      inSources = true;
      continue;
    }
    if (inSources && /^#{1,4}\s+/.test(line)) {
      inSources = false;
      continue;
    }
    if (!inSources) continue;
    const matches = line.matchAll(/\[([^\]]+)\]\((https?:\/\/[^\)]+)\)/g);
    for (const m of matches) {
      out.push({ title: m[1].trim(), url: m[2].trim(), origin });
    }
  }
  return out;
}

const references = await getCollection('reference');
const research = await getCollection('research');
const whitepaper = await getCollection('whitepaper');

const all: Entry[] = [];
for (const d of references) all.push(...extractSources(d.body ?? '', `reference/${d.id}`));
for (const d of research) all.push(...extractSources(d.body ?? '', `research/${d.id}`));
for (const d of whitepaper) all.push(...extractSources(d.body ?? '', `whitepaper/${d.id}`));

// Deduplicate by normalized URL
const byUrl = new Map<string, Entry & { origins: Set<string> }>();
for (const e of all) {
  const url = e.url.replace(/[.,;]+$/, '');
  const existing = byUrl.get(url);
  if (existing) {
    existing.origins.add(e.origin);
  } else {
    byUrl.set(url, { ...e, url, origins: new Set([e.origin]) });
  }
}

const sorted = Array.from(byUrl.values()).sort((a, b) =>
  a.title.toLowerCase().localeCompare(b.title.toLowerCase())
);

// Group by first letter
const groups: Record<string, typeof sorted> = {};
for (const e of sorted) {
  const letter = e.title.charAt(0).toUpperCase();
  const key = /[A-Z]/.test(letter) ? letter : '#';
  (groups[key] ||= []).push(e);
}
const letters = Object.keys(groups).sort();
---
<BaseLayout title="Bibliography">
  <h1>Bibliography</h1>
  <p style="font-family: 'Spectral', serif; font-style: italic; font-size: 1.1rem; color: var(--text-muted); margin-bottom: 2rem;">
    Every external source cited across the ZAOfractal repo, deduplicated and alphabetized.
    {sorted.length} entries. For ZAO-internal cross-references, see <a href="/resources">Resources</a>.
  </p>

  <nav class="biblio-jump" aria-label="Jump to letter">
    {letters.map((l) => <a href={`#l-${l}`}>{l}</a>)}
  </nav>

  {letters.map((l) => (
    <section class="biblio-section">
      <h2 id={`l-${l}`} class="biblio-letter">{l}</h2>
      <ol class="biblio-list">
        {groups[l].map((e) => (
          <li>
            <cite><a href={e.url} target="_blank" rel="noopener noreferrer">{e.title}</a></cite>
            <span class="biblio-origins">{Array.from(e.origins).length} citation{Array.from(e.origins).length === 1 ? '' : 's'}</span>
          </li>
        ))}
      </ol>
    </section>
  ))}
</BaseLayout>

<style>
  .biblio-jump {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1rem 0 2.5rem;
    padding: 0.75rem 1rem;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.8rem;
  }
  .biblio-jump a {
    color: var(--text-muted);
    border: none;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
  }
  .biblio-jump a:hover {
    background: var(--bg-card);
    color: var(--orange);
  }
  .biblio-section {
    margin-bottom: 2rem;
  }
  .biblio-letter {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.8rem;
    color: var(--orange);
    margin: 2rem 0 1rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--rule);
    scroll-margin-top: 5rem;
  }
  .biblio-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: 'Spectral', Georgia, serif;
    font-size: 0.98rem;
    line-height: 1.6;
  }
  .biblio-list li {
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .biblio-list cite {
    font-style: italic;
    flex: 1;
    min-width: 0;
  }
  .biblio-list cite a {
    color: var(--text);
    border-bottom: 1px dashed var(--rule);
    word-break: break-word;
  }
  .biblio-list cite a:hover {
    color: var(--orange);
    border-bottom-color: var(--orange);
  }
  .biblio-origins {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.7rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
</style>
