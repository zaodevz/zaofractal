---
import { getCollection, render } from 'astro:content';
import DocLayout from '../../layouts/DocLayout.astro';

export async function getStaticPaths() {
  const deriveTitle = (slug: string, body: string | undefined): string => {
    const h1 = body?.match(/^#\s+(.+)$/m)?.[1];
    if (h1) return h1.trim();
    return slug.split('/').pop()!.replace(/\.md$/, '').replace(/^\d+-/, '').replace(/-/g, ' ');
  };

  const docs = await getCollection('research');
  // Group by top-level folder so prev/next walks within a folder, not across the whole collection
  // (otherwise you'd jump from research/04 to research/code-walk/01 which is jarring).
  const groups = new Map<string, typeof docs>();
  for (const doc of docs) {
    const top = doc.id.includes('/') ? doc.id.split('/')[0] : '__top__';
    if (!groups.has(top)) groups.set(top, []);
    groups.get(top)!.push(doc);
  }
  const paths: any[] = [];
  for (const [, list] of groups) {
    list.sort((a, b) => {
      if (a.id.toLowerCase().includes('readme') && !b.id.toLowerCase().includes('readme')) return -1;
      if (b.id.toLowerCase().includes('readme') && !a.id.toLowerCase().includes('readme')) return 1;
      if (a.id.toLowerCase().includes('index') && !b.id.toLowerCase().includes('index')) return -1;
      if (b.id.toLowerCase().includes('index') && !a.id.toLowerCase().includes('index')) return 1;
      return a.id.localeCompare(b.id);
    });
    list.forEach((doc, i) => {
      const prevDoc = list[i - 1] ?? null;
      const nextDoc = list[i + 1] ?? null;
      paths.push({
        params: { slug: doc.id.replace(/\.md$/, '') },
        props: {
          doc,
          prev: prevDoc
            ? { href: `/research/${prevDoc.id.replace(/\.md$/, '')}`, title: deriveTitle(prevDoc.id, prevDoc.body) }
            : null,
          next: nextDoc
            ? { href: `/research/${nextDoc.id.replace(/\.md$/, '')}`, title: deriveTitle(nextDoc.id, nextDoc.body) }
            : null,
        },
      });
    });
  }
  return paths;
}

const { doc, prev, next } = Astro.props;
const { Content, headings } = await render(doc);
const fm: any = (doc as any).data ?? {};

const h1 = doc.body?.match(/^#\s+(.+)$/m)?.[1];
const title = h1 ?? doc.id;
---
<DocLayout
  title={title}
  collection="research"
  slug={doc.id.replace(/\.md$/, '')}
  frontmatter={fm}
  headings={headings}
  prev={prev}
  next={next}
>
  <Content />
</DocLayout>
